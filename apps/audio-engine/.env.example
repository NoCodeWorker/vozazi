# API Configuration
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vozazi

# Cloudflare R2 Storage
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=vozazi-audio
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Redis Cache
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Audio Processing
AUDIO_TEMP_DIR=/tmp/audio
AUDIO_MAX_FILE_SIZE=104857600
AUDIO_SUPPORTED_FORMATS=mp3,wav,ogg,flac,m4a

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://vozazi.com
